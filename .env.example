# Example environment variables (do NOT commit real secrets)

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Next / App settings
NEXT_PUBLIC_API_BASE=/api
NEXTAUTH_SECRET=your_nextauth_secret_here

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# PayPal (sandbox)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# M-Pesa (sandbox)
MPESA_API_KEY=
MPESA_API_URL=
# HMAC-SHA256 secret used to verify M-Pesa webhook signatures (required in prod)
MPESA_WEBHOOK_SECRET=

# Shared secret required to trigger the billing CRON endpoint
CRON_SECRET_KEY=

# Bearer token required to access the admin summary API
ADMIN_API_SECRET=

# Email provider (optional)
SENDGRID_API_KEY=

# Application settings
TAX_PERCENT=2
NODE_VERSION=18

# Optional
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
