// src/app/dashboard/page.tsx
import { prisma } from "@/lib/db";
import { CreditCard, Smartphone, ShieldAlert, ArrowUpRight, Activity } from "lucide-react";

export const revalidate = 0; // Force server-side rendering for critical live balances

export default async function DashboardPage() {
  // Query transactional data sets directly from PostgreSQL via Prisma
  const metrics = await prisma.wallet.findMany();
  const recentTransactions = await prisma.transaction.findMany({
    take: 5,
    orderBy: { createdAt: "desc" },
    include: { paymentMethod: true },
  });

  return (
    <div className="min-h-screen bg-gray-950 text-gray-100 p-6 font-sans">
      <header className="mb-8 flex justify-between items-center border-b border-gray-800 pb-5">
        <div>
          <h1 className="text-3xl font-extrabold tracking-tight text-white">RafikiPay</h1>
          <p className="text-sm text-gray-400 mt-1">Global-Local Subscription Balancing Node</p>
        </div>
        <span className="flex items-center gap-2 bg-emerald-950 text-emerald-400 border border-emerald-800 px-3 py-1 rounded-full text-xs font-semibold">
          <Activity size={14} /> Production Environment Secure
        </span>
      </header>

      {/* Multi-Currency Balances Row */}
      <h2 className="text-lg font-bold text-gray-300 mb-4 flex items-center gap-2">Core Ledger Balances</h2>
      <div className="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        {metrics.map((wallet) => (
          <div key={wallet.id} className="bg-gradient-to-br from-gray-900 to-gray-950 border border-gray-800 rounded-xl p-6 shadow-2xl relative overflow-hidden">
            <div className="absolute right-4 top-4 text-gray-800 text-6xl font-black select-none z-0">{wallet.currency}</div>
            <div className="relative z-10">
              <p className="text-xs uppercase font-bold text-gray-500 tracking-wider">{wallet.currency === "KES" ? "Local Mobile/Bank Rail Vault" : "Global Card Settlement Vault"}</p>
              <p className="text-4xl font-mono font-bold mt-2 text-white">
                {wallet.currency} {parseFloat(wallet.balance.toString()).toLocaleString(undefined, { minimumFractionDigits: 2 })}
              </p>
            </div>
          </div>
        ))}
      </div>

      {/* Real-Time Transaction Logs Ledger */}
      <div className="bg-gray-900 border border-gray-800 rounded-xl shadow-xl overflow-hidden">
        <div className="p-5 border-b border-gray-800 bg-gray-900/50 flex justify-between items-center">
          <h3 className="font-bold text-gray-200">Recent Transaction Flow (Double-Entry Logged)</h3>
          <span className="text-xs text-gray-500">Live Updates</span>
        </div>
        <div className="divide-y divide-gray-800">
          {recentTransactions.length === 0 ? (
            <p className="p-6 text-gray-500 text-center text-sm">No recent transactions recorded on this node.</p>
          ) : (
            recentTransactions.map((tx) => (
              <div key={tx.id} className="p-4 flex items-center justify-between hover:bg-gray-800/30 transition-colors">
                <div className="flex items-center gap-4">
                  <div className="p-2.5 bg-gray-950 border border-gray-700 rounded-lg text-gray-400">
                    {tx.paymentMethod.gateway.includes("MPESA") ? <Smartphone size={20} className="text-emerald-400" /> : <CreditCard size={20} className="text-blue-400" />}
                  </div>
                  <div>
                    <p className="text-sm font-semibold text-white">{tx.paymentMethod.gateway.replace("_", " ")}</p>
                    <p className="text-xs text-gray-500 mt-0.5 font-mono">Ref: {tx.gatewayRef || "Awaiting Gateway Handshake"}</p>
                  </div>
                </div>
                <div className="text-right">
                  <p className={`text-sm font-bold font-mono ${tx.status === "SUCCESS" ? "text-emerald-400" : tx.status === "PENDING" ? "text-amber-400" : "text-rose-500"}`}>
                    {tx.currency} {parseFloat(tx.amount.toString()).toFixed(2)}
                  </p>
                  <span className="text-[10px] uppercase font-extrabold tracking-wider opacity-60 px-1.5 py-0.5 rounded bg-gray-950 border border-gray-800 mt-1 inline-block text-gray-300">
                    {tx.status}
                  </span>
                </div>
              </div>
            ))
          )}
        </div>
      </div>
    </div>
  );
}
