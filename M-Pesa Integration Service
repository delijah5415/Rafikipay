// src/services/mpesa.service.ts
import { decryptSensitiveData } from "@/lib/crypto";

export class MpesaService {
  private consumerKey = process.env.MPESA_CONSUMER_KEY!;
  private consumerSecret = process.env.MPESA_CONSUMER_SECRET!;
  private baseUrl = process.env.MPESA_ENV === "production" 
    ? "https://api.safaricom.co.ke" 
    : "https://sandbox.safaricom.co.ke";

  /**
   * Generates a short-lived Bearer token for Daraja authentication via TLS 1.3
   */
  private async generateOAuthToken(): Promise<string> {
    const auth = Buffer.from(`${this.consumerKey}:${this.consumerSecret}`).toString("base64");
    const response = await fetch(`${this.baseUrl}/oauth/v1/generate?grant_type=client_credentials`, {
      method: "GET",
      headers: { Authorization: `Basic ${auth}` },
    });

    if (!response.ok) throw new Error("MPESA_AUTH_FAILURE: Unable to provision access token.");
    const data = await response.json();
    return data.access_token;
  }

  /**
   * Triggers an interactive C2B STK Push (M-Pesa Express) request to provision the initial subscription 
   */
  public async triggerStkPush(phoneNumber: string, amount: number, accountReference: string): Promise<any> {
    const token = await this.generateOAuthToken();
    const timestamp = new Date().toISOString().replace(/[-:T.]/g, "").slice(0, 14);
    const password = Buffer.from(
      `${process.env.MPESA_SHORTCODE}${process.env.MPESA_PASSKEY}${timestamp}`
    ).toString("base64");

    const payload = {
      BusinessShortCode: process.env.MPESA_SHORTCODE,
      Password: password,
      Timestamp: timestamp,
      TransactionType: "CustomerPayBillOnline",
      Amount: Math.ceil(amount),
      PartyA: phoneNumber,
      PartyB: process.env.MPESA_SHORTCODE,
      PhoneNumber: phoneNumber,
      CallBackURL: `${process.env.NEXT_PUBLIC_APP_URL}/api/v1/webhooks/mpesa`,
      AccountReference: accountReference,
      TransactionDesc: "Subscription Registration Payment",
    };

    const response = await fetch(`${this.baseUrl}/mpesa/stkpush/v1/processrequest`, {
      method: "POST",
      headers: {
        Authorization: `Bearer ${token}`,
        "Content-Type": "application/json",
      },
      body: JSON.stringify(payload),
    });

    return await response.json();
  }

  /**
   * Triggers a completely autonomous, non-interactive deduction utilizing a Standing Order token
   */
  public async triggerStandingOrderDeduction(encryptedToken: string, amount: number): Promise<{ success: boolean; gatewayReferenceId?: string }> {
    try {
      const token = await this.generateOAuthToken();
      const directStandingOrderId = await decryptSensitiveData(encryptedToken);

      // Call the Safaricom Standing Orders API route execution line
      const response = await fetch(`${this.baseUrl}/mpesa/standingorders/v1/execute`, {
        method: "POST",
        headers: {
          Authorization: `Bearer ${token}`,
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          StandingOrderId: directStandingOrderId,
          Amount: amount,
        }),
      });

      const result = await response.json();
      
      if (response.ok && result.ResponseCode === "0") {
        return { success: true, gatewayReferenceId: result.TransactionID };
      }
      return { success: false };
    } catch (error) {
      console.error("MPESA_STANDING_ORDER_CRASH: ", error);
      return { success: false };
    }
  }
}

export const mpesaService = new MpesaService();
